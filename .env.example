# YouTube API Key (get from Google Cloud Console)
YOUTUBE_API_KEY=your_youtube_api_key_here

# PostgreSQL (matches docker-compose.yml defaults)
DATABASE_URL=postgresql://postgres:postgres@localhost:5435/youtube_manager

# Google OAuth 2.0 (optional — needed for scheduled/private videos)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/callback
